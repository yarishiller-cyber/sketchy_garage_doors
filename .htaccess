# .htaccess — copy to each site repo root. Hostinger (Apache) reads this on deploy.
# Force HTTPS + canonical host, gzip, long-cache static assets, and protect internal files.

# ---- Clean URLs (FLEET-STANDARDS §0) + HTTPS -----------------------------------------
# Pages are flat page.html files on disk, but every public URL is extensionless /page/.
Options +FollowSymLinks -Indexes
DirectoryIndex index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Force HTTPS (also honour reverse-proxy header)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # strip index.html (root or subdir) -> directory
  RewriteCond %{THE_REQUEST} \s/+(([^?\s]*/)?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
  # /page.html -> /page/   (301; consolidates old links)
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]
  # serve /page/ (or /page) from /page.html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^([^/]+)/?$ $1.html [L]
  # serve nested /dir/page/ from /dir/page.html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.+?)/?$ $1.html [L]
  # block internal/dev dirs
  RewriteRule ^(_build|_shared)/ - [F,L]
</IfModule>

# ---- Canonical host: pick ONE (uncomment the non-www -> www OR the reverse) ----------
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ---- Protect internal / brain files from being served on the public site -------------
# The _shared submodule and any markdown (incl. CREDENTIALS.md) must never be downloadable.
RedirectMatch 404 ^/_shared/
<FilesMatch "\.(md|json|mjs|sh|gitmodules)$">
  Require all denied
</FilesMatch>
# Allow the site's own public JSON if needed (e.g. manifest) by exception:
<Files "site.webmanifest">
  Require all granted
</Files>

# ---- Gzip / compression --------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>

# ---- Cache static assets long; HTML short --------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ---- Security/UX headers -------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  # HSTS — safe here: the whole site is HTTPS-only (forced above).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Content-Security-Policy. Fonts are self-hosted (no Google domains). Motion ships from
  # jsDelivr; inline <script type=module> + inline style="" attributes need 'unsafe-inline'.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://cdn.jsdelivr.net; form-action 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests"

  # Long-cache the fingerprinted fonts.
  <FilesMatch "\.woff2$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# woff2 mime (older Apache)
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
</IfModule>

ErrorDocument 404 /404.html
